IFNDEF _CHARS_INC
DEFINE _CHARS_INC

; character constants

CHAR_BS    equ 0x08 ; \b backspace
CHAR_TAB   equ 0x09 ; \t tab
CHAR_LF    equ 0x0a ; \n linefeed
CHAR_CR    equ 0x0d ; \r carriage return
CHAR_ESC   equ 0x1b ; \e escape
CHAR_SLASH equ 0x5c ; \\ backslash
CHAR_QUOTE equ 0x27 ; \' single quote
CHAR_DEL   equ 0x7f ; DEL (backspace key on most terminals)

ENDIF
